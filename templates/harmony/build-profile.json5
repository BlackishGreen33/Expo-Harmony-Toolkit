{
  app: {
    products: [
      {
        name: 'default',
        signingConfig: 'default',
        compatibleSdkVersion: '5.0.0(12)',
        targetSdkVersion: '6.0.0(20)',
        runtimeOS: 'HarmonyOS',
        buildOption: {
          nativeCompiler: 'BiSheng'
        }
      },
    ],
    buildModeSet: [
      {
        name: 'debug',
      },
      {
        name: 'release',
      },
    ],
    signingConfigs: [],
  },
  modules: [
    {
      name: '{{ENTRY_MODULE_NAME}}',
      srcPath: './entry',
      targets: [
        {
          name: 'default',
          applyToProducts: ['default'],
        },
      ],
    },
  ],
}
