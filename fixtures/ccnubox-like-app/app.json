{
  "expo": {
    "name": "CCNUBox Like App",
    "slug": "ccnubox-like",
    "version": "1.0.0",
    "scheme": "ccnubox",
    "plugins": [
      "expo-router",
      "mx-jpush-expo",
      "@bacons/apple-targets",
      "./plugins/config-android-url-scheme.js"
    ],
    "extra": {
      "expoHarmony": {
        "doctor": {
          "excludeDependencies": [
            "@bacons/apple-targets"
          ],
          "excludePlugins": [
            "@bacons/apple-targets",
            "./plugins/config-android-url-scheme.js",
            "mx-jpush-expo"
          ],
          "coverageProfile": "managed-native-heavy"
        }
      }
    },
    "android": {
      "package": "com.example.ccnuboxlike"
    },
    "ios": {
      "bundleIdentifier": "com.example.ccnuboxlike"
    }
  }
}
